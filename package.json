{
  "name": "cadenza",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "android:phone": "$ANDROID_HOME/emulator/emulator -avd Pixel_7 & $ANDROID_HOME/platform-tools/adb wait-for-device && expo start --android",
    "android:tablet": "$ANDROID_HOME/emulator/emulator -avd Pixel_Tablet & $ANDROID_HOME/platform-tools/adb wait-for-device && expo start --android",
    "ios": "expo start --ios",
    "ios:iphone": "expo start --ios --device \"iPhone 15\"",
    "ios:ipad": "expo start --ios --device \"iPad Pro 11-inch (M4)\"",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
