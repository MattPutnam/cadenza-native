{
  "name": "cadenza",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:phone": "$ANDROID_HOME/emulator/emulator -avd Pixel_7 & $ANDROID_HOME/platform-tools/adb wait-for-device && expo start --android",
    "android:tablet": "$ANDROID_HOME/emulator/emulator -avd Pixel_Tablet & $ANDROID_HOME/platform-tools/adb wait-for-device && expo start --android",
    "ios": "expo run:ios",
    "ios:iphone": "xcrun simctl boot 'iPhone 17' || true; open -a Simulator && expo start --ios",
    "ios:ipad": "xcrun simctl boot 'iPad Pro 11-inch (M5)' || true; open -a Simulator && expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "storybook": "EXPO_PUBLIC_STORYBOOK=true expo start",
    "storybook:generate": "sb-rn-get-stories --config-path .storybook"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/",
      "/ios/",
      "/android/",
      "/__tests__/helpers/"
    ],
    "moduleNameMapper": {
      "^@react-native-async-storage/async-storage$": "@react-native-async-storage/async-storage/jest/async-storage-mock",
      "^.*/modules/expo-cadenza-midi$": "<rootDir>/__mocks__/modules/expo-cadenza-midi.js"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-dev-client": "~6.0.20",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@storybook/react-native": "^7.6.20",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
